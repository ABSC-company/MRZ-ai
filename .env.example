COMPOSE_PROJECT_NAME=mrz-service
DOMAIN=localhost
MAX_REQUEST_SIZE=22MB

ENVIRONMENT=production
ENABLE_DOCS=1
LOG_LEVEL=INFO
TRUSTED_HOSTS=localhost,127.0.0.1
API_KEY_REQUIRED=1
API_KEY_FILE=secrets/api_key.txt

MAX_UPLOAD_MB=20
MAX_IMAGE_PIXELS=60000000
MAX_DOCUMENT_PAGES=10

MRZ_DEVICE=cuda
MRZ_MAX_CROPS=2
MRZ_TRY_UPSIDE_DOWN=1
MRZ_ORIENTATION_RETRY=1
MRZ_USE_EASYOCR=1
MRZ_EASYOCR_AGGRESSIVE=1

FALLBACK_ENABLED=1
FALLBACK_REQUIRED=1
FALLBACK_DEVICE=cuda
FALLBACK_THRESHOLD=0.40
FALLBACK_CROP_PADDING=0.08
FALLBACK_OCR_LANGS=ru,en
